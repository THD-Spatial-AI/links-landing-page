{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start MkDocs server",
            "type": "shell",
            "command": "pip install -r requirements.txt && mkdocs serve -a localhost:5000",
            "runOptions": {
                "runOn": "folderOpen",
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Generate and serve site pages",
            "type": "shell",
            "command": "python3 scripts/generate.py && python3 -m http.server 3000 --directory _site",
            "runOptions": {
                "runOn": "folderOpen",
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ],
}